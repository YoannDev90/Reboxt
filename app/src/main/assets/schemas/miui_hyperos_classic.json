{
  "id": "miui_hyperos_classic",
  "name": "MIUI/HyperOS Standard",
  "steps": [
    {
      "type": "launch_intent",
      "value": "com.android.settings/.Settings$BatterySettingsActivity",
      "action": "launch"
    },
    {
      "type": "find_id",
      "value": "com.miui.securitycenter:id/battery_extra_features",
      "action": "click"
    },
    {
      "type": "find_id",
      "value": "com.miui.securitycenter:id/schedule_power_on_off",
      "action": "click"
    }
  ]
}
